<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fundo -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background2"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Overlay escuro -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <!-- Conteúdo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <Button
            android:id="@+id/btn190"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/emergencia_policia"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn180"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/emergencia_central"
            android:layout_marginTop="12dp"
            android:backgroundTint="#C2185B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn192"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/emergencia_samu"
            android:layout_marginTop="12dp"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/acao_voltar"
            android:layout_marginTop="24dp"
            android:backgroundTint="#616161"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</FrameLayout>